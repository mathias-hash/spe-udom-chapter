SECRET_KEY=replace-this-in-production-use-strong-random-key
DEBUG=False
ALLOWED_HOSTS=your-backend-domain.onrender.com,your-backend-domain.up.railway.app,localhost,127.0.0.1

# Security Settings
ENFORCE_HTTPS=True
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# CORS & CSRF
CORS_ALLOWED_ORIGINS=https://your-frontend-domain.netlify.app,https://your-frontend-domain.vercel.app,http://localhost:3000
CSRF_TRUSTED_ORIGINS=https://your-frontend-domain.netlify.app,https://your-frontend-domain.vercel.app,http://localhost:3000
TRUSTED_ORIGINS=https://your-frontend-domain.netlify.app,https://your-frontend-domain.vercel.app,http://localhost:3000

# Database
DATABASE_URL=sqlite:///db.sqlite3

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=SPE UDOM Chapter <noreply@speudom.ac.tz>

# Password Reset
PASSWORD_RESET_CONFIRM_URL=https://your-frontend-domain/reset-password

# Redis Configuration (for WebSocket support)
CHANNELS_REDIS_URL=redis://localhost:6379/0

# Optional: Sentry Error Tracking
SENTRY_ENABLED=False
SENTRY_DSN=

# Session Security
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
CSRF_COOKIE_SECURE=True
CSRF_COOKIE_HTTPONLY=True

# Optional: AWS S3 for Media Files
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
